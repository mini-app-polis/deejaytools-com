DATABASE_URL=postgresql://user:password@localhost:5432/deejaytools
CLERK_JWKS_URL=https://clerk.deejaytools.com/.well-known/jwks.json
CORS_ORIGINS=http://localhost:5173,https://deejaytools.com
# Google Drive — service account for song file uploads
# Create a service account in Google Cloud Console with Drive API access
# Share the target Drive folder with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_PARENT_FOLDER_ID=
PORT=3001
NODE_ENV=development
# Optional. Maximum number of Postgres connections in the pool (default: 20).
# Set lower than your Railway plan's connection limit to leave headroom.
DB_POOL_MAX=20
# Optional. Seconds to wait when opening a new DB connection before giving up (default: 10).
DB_CONNECT_TIMEOUT=10
# Optional. Seconds an idle connection is kept open before being released (default: 30).
DB_IDLE_TIMEOUT=30
# Optional. When set, GET /internal/tick requires header x-tick-secret matching this value (Railway cron).
TICK_SECRET=
# Brevo — transactional email for feedback submissions.
# Get your API key from app.brevo.com → SMTP & API → API Keys.
# When unset, feedback submissions are accepted but no email is sent.
BREVO_API_KEY=
# Sentry
# Get DSN from sentry.io — create a Node.js project under deejaytools-com
SENTRY_DSN=
